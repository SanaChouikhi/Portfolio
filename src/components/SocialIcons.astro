---
const {width, height} = Astro.props;
const socialLinks = [
	{
		title: 'LinkedIn',
		icon: 'simple-icons:linkedin',
		href: 'https://www.linkedin.com/in/sana-chouikhi-00aa6a217',
	},
	{
		title: 'GitHub',
		icon: 'mdi:github',
		href: 'https://github.com/SanaChouikhi',
	},
	{
		title: 'Instagram',
		icon: 'mdi:instagram',
		href: 'https://www.instagram.com/',
	},
	{
		title: 'Twitter',
		icon: 'ri:twitter-x-fill',
		href: 'https://twitter.com/',
	},
	{
		title: 'CV',
		icon: 'tabler:file-cv',
		href: '../docs/CV_CHOUIKHI_SANA.pdf',
	},
];
---

<div class="icons__container">
	{
		socialLinks.map((data) => (
			<a
				href={data.href}
				target="_blank"
				rel="nofollow noreferrer noopener"
				title={data.title}
			>
				<iconify-icon
					class={`skill__icon ${data.title}`}
					icon={data.icon}
					width={width}
					height={height}
				/>
			</a>
		))
	}
</div>

<style>
	.icons__container {
		display: flex;
		width: fit-content;
		justify-content: flex-start;
		align-items: center;
		gap: 1.8rem;
	}
	.skill__icon {
		color: #dcd8fc;
		transition: color 0.2s ease, transform 0.2s ease;
		cursor: pointer;
		display: block;
	}
	.skill__icon:hover { transform: translateY(-2px); }
	.LinkedIn:hover  { color: #0e76a8; }
	.Instagram:hover { color: #E1306C; }
	.Twitter:hover   { color: #0aa5f6; }
	.GitHub:hover    { color: #ffffff; }
	.CV:hover        { color: #8e64ff; }
</style>