---
import SocialIcons from '../SocialIcons.astro';
import Title from '../atoms/Title.astro';
import "./about.css"
---

<section id="about" class="about">
	<div class="about__container">

		<div class="about__card-identity">
			<div class="about__avatar-placeholder">
				<span class="about__initials">SC</span>
				<div class="about__avatar-ring"></div>
			</div>
			<h3 class="about__name">Sana Chouikhi</h3>
			<p class="about__role">Software Engineer</p>
			<div class="about__location">
				<iconify-icon icon="lucide:map-pin" width="16"></iconify-icon>
				Tunis, Tunisia 🇹🇳
			</div>
			<div class="about__contact">
				<a href="mailto:sanachouikhi1999@gmail.com" class="about__contact-link">
					<iconify-icon icon="fluent:mail-28-regular" width="16"></iconify-icon>
					sanachouikhi1999@gmail.com
				</a>
				<a href="tel:+21626603287" class="about__contact-link">
					<iconify-icon icon="lucide:phone" width="16"></iconify-icon>
					+216 26 603 287
				</a>
			</div>
			<SocialIcons width="22" height="22"/>
			<div class="about__tags">
				<span class="tag">💼 Available for hire</span>
				<span class="tag">🎓 Software Engineer</span>
				<span class="tag">🌍 Remote friendly</span>
			</div>
			<div class="about__langs">
				<span class="lang-badge">🇹🇳 Arabic</span>
				<span class="lang-badge">🇫🇷 French</span>
				<span class="lang-badge">🇬🇧 English</span>
				<span class="lang-badge">🇩🇪 German</span>
			</div>
		</div>

		<div class="about__content">
			<Title margin="1rem" contenido="About Me" />

			<p class="about__text">
				Software Engineer specialised in <strong>ERP platforms</strong>, <strong>backend engineering</strong>,
				<strong>business automation</strong> and <strong>production infrastructure</strong>.
				Proven ability to design and deliver scalable technical solutions across operations, finance, APIs,
				cloud environments, and secure systems. Experienced in cross-functional teams and
				international remote collaboration.
			</p>

			<div class="about__highlights">
				<div class="about__highlight-item">
					<div class="about__highlight-icon">⚙️</div>
					<div>
						<h4>ERP & Automation</h4>
						<p>ERPNext, Frappe Framework, n8n — 80% reduction in manual processing</p>
					</div>
				</div>
				<div class="about__highlight-item">
					<div class="about__highlight-icon">☁️</div>
					<div>
						<h4>DevOps & Cloud</h4>
						<p>Docker, GitHub Actions, OVHcloud VPS, AWS, Linux Administration</p>
					</div>
				</div>
				<div class="about__highlight-item">
					<div class="about__highlight-icon">🔧</div>
					<div>
						<h4>Backend Engineering</h4>
						<p>Python / Django REST, Node.js / Express, REST APIs, System Design</p>
					</div>
				</div>
				<div class="about__highlight-item">
					<div class="about__highlight-icon">📊</div>
					<div>
						<h4>Observability</h4>
						<p>Prometheus, Grafana, Loki, Wazuh — production monitoring</p>
					</div>
				</div>
				<div class="about__highlight-item">
					<div class="about__highlight-icon">💻</div>
					<div>
						<h4>Frontend & Mobile</h4>
						<p>React.js, Angular, Flutter, React Native, TypeScript, Tailwind CSS</p>
					</div>
				</div>
				<div class="about__highlight-item">
					<div class="about__highlight-icon">🔒</div>
					<div>
						<h4>Security & Infrastructure</h4>
						<p>HashiCorp Vault, SSL/TLS, SPF/DKIM/DMARC, Linux Hardening</p>
					</div>
				</div>
			</div>

			<!-- ── Experience Timeline ── -->
			<div class="about__timeline">
				<h3 class="about__timeline-title">Experience</h3>

				<!-- 1 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>ERP Software Engineer & IT Systems</h4>
							<span class="timeline__date">Mar 2025 – Present</span>
						</div>
						<p class="timeline__company">Arkeyez — Tataouine, Tunisia</p>
						<p class="timeline__desc">Custom ERP modules (ERPNext/Frappe), n8n automation (−80% manual processing), CI/CD with GitHub Actions, containerised stack on OVHcloud VPS, monitoring with Prometheus/Grafana/Loki, full enterprise email infrastructure (SMTP/SPF/DKIM/DMARC).</p>
					</div>
				</div>

				<!-- 2 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Full-Stack Developer (Web & Mobile)</h4>
							<span class="timeline__date">Sep 2024 – Feb 2025</span>
						</div>
						<p class="timeline__company">Freelancer.com — Remote</p>
						<p class="timeline__desc">Production-grade applications for international clients. Django REST Framework, Node.js/Express, React.js, cross-platform mobile apps, third-party API integrations (payment, messaging, mapping).</p>
					</div>
				</div>

				<!-- 3 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Software Engineering Intern — IoT Platform</h4>
							<span class="timeline__date">Feb 2024 – Jul 2024</span>
						</div>
						<p class="timeline__company">Enova Robotics — Sousse, Tunisia</p>
						<p class="timeline__desc">Real-time IoT monitoring platform for autonomous security robots. React.js, Node.js, MongoDB, Python, MQTT for command/control, RTSP for live video streaming. Dashboards improved operational decisions by 40%.</p>
					</div>
				</div>

				<!-- 4 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Mobile Application Developer Intern</h4>
							<span class="timeline__date">Jul 2023 – Aug 2023</span>
						</div>
						<p class="timeline__company">Online VIP Consulting — Remote</p>
						<p class="timeline__desc">Banking mobile app features with React Native, REST API integrations, collaboration with remote backend teams to optimise API contracts.</p>
					</div>
				</div>

				<!-- 5 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Observation Internship — Mobile App</h4>
							<span class="timeline__date">Jul 2022 – Aug 2022</span>
						</div>
						<p class="timeline__company">Tunisie Telecom — Medenine, Tunisia</p>
						<p class="timeline__desc">Full mobile application for field GSM site management using Flutter, Node.js and MySQL. Interactive maps, site details, photo uploads and QR code scanning. Reduced field engineers' issue reporting time by 50%.</p>
					</div>
				</div>

				<!-- 6 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Final Year Project — Virtual Classroom</h4>
							<span class="timeline__date">Feb 2021 – Jun 2021</span>
						</div>
						<p class="timeline__company">Sindibad Group — Tunis, Tunisia</p>
						<p class="timeline__desc">Real-time virtual classroom platform (web + mobile) used by hundreds of students. WebRTC for audio/video calls, interactive whiteboard, live chat and screen sharing. Backend built with Node.js, Socket.io and MySQL.</p>
					</div>
				</div>

				<!-- 7 -->
				<div class="timeline__item">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Advanced Internship — Management System</h4>
							<span class="timeline__date">Jan 2020 – Feb 2020</span>
						</div>
						<p class="timeline__company">Institut des Régions Arides — Medenine, Tunisia</p>
						<p class="timeline__desc">Full-stack internal management system using PHP, Bootstrap and MySQL. Supported employee management and equipment tracking processes. Significantly reduced manual record-keeping and search time.</p>
					</div>
				</div>

				<!-- 8 -->
				<div class="timeline__item timeline__item--last">
					<div class="timeline__dot"></div>
					<div class="timeline__content">
						<div class="timeline__header">
							<h4>Introductory Internship — Website Development</h4>
							<span class="timeline__date">Jan 2019 – Feb 2019</span>
						</div>
						<p class="timeline__company">Regional Directorate — Medenine, Tunisia</p>
						<p class="timeline__desc">Responsive institutional website using HTML, CSS, Bootstrap and JavaScript. Optimised for fast loading and accessibility.</p>
					</div>
				</div>

			</div>

			<!-- ── Education ── -->
			<div class="about__education">
				<h3 class="about__timeline-title">Education</h3>
				<div class="edu__grid">
					<div class="edu__item">
						<iconify-icon icon="lucide:graduation-cap" width="20"></iconify-icon>
						<div>
							<h4>Engineering Degree in Computer Science</h4>
							<p>ISSATS Sousse — 2021–2024</p>
						</div>
					</div>
					<div class="edu__item">
						<iconify-icon icon="lucide:book-open" width="20"></iconify-icon>
						<div>
							<h4>Bachelor's Degree in Embedded Systems</h4>
							<p>ISET Medenine — 2018–2021</p>
						</div>
					</div>
				</div>
			</div>

			<!-- ── Certifications ── -->
			<div class="about__certs">
				<h3 class="about__timeline-title">Certifications</h3>
				<div class="certs__grid">
					<span class="cert__badge">Full-Stack Frappe Framework — 2026</span>
					<span class="cert__badge">Python Programming — 2020</span>
					<span class="cert__badge">C for Embedded Systems — 2020</span>
					<span class="cert__badge">Introduction to IoT — 2020</span>
					<span class="cert__badge">JavaScript, Bootstrap & PHP — 2019</span>
					<span class="cert__badge">Networking Fundamentals — 2019</span>
				</div>
			</div>

		</div>
	</div>
</section>